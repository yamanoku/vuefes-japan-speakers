{
  "compilerOptions": {
    "target": "ES2024",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "types": ["node", "vite/client"]
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.vue",
    "server/**/*.ts",
    "types/**/*.ts",
    "env.d.ts",
    "vite.config.ts"
  ]
}
