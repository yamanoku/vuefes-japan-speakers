{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vuefes-japan-speakers",
  "compatibility_date": "2026-04-25",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./dist/server/index.js",
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
  },
  "observability": {
    "enabled": true,
  },
}
