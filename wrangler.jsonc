{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vuefes-japan-speakers",
  "compatibility_date": "2026-04-25",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./.output/server/index.mjs",
  "assets": {
    "directory": "./.output/public",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}