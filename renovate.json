{
  "extends": ["config:recommended", "helpers:pinGitHubActionDigests"],
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "rangeStrategy": "bump",
  "labels": ["dependencies"],
  "dependencyDashboard": false,
  "automerge": true,
  "major": {
    "automerge": false
  },
  "schedule": ["after 10pm every weekday", "before 6am every weekday"],
  "assignees": ["yamanoku"],
  "packageRules": [
    {
      "description": "vuerend関連のパッケージは1つのPRにまとめる",
      "groupName": "vuerend packages",
      "matchPackageNames": ["@vuerend/**"]
    },
    {
      "description": "Vue関連のパッケージは1つのPRにまとめる",
      "groupName": "Vue packages",
      "matchPackageNames": ["vue", "vue-tsc", "@vue/**"]
    },
    {
      "description": "Iconify関連のパッケージは1つのPRにまとめる",
      "groupName": "Iconify packages",
      "matchPackageNames": ["@iconify-json/**"]
    },
    {
      "description": "Test関連のパッケージは1つのPRにまとめる",
      "groupName": "Test packages",
      "matchPackageNames": ["@vue/test-utils", "playwright"]
    },
    {
      "description": "Vize関連のパッケージは1つのPRにまとめる",
      "groupName": "Vize packages",
      "matchPackageNames": ["vize", "@vizejs/**", "oxlint", "oxlint-plugin-vize"]
    },
    {
      "description": "Vite Plus関連のパッケージは1つのPRにまとめる",
      "groupName": "Vite packages",
      "matchPackageNames": [
        "vite",
        "@vitejs/**",
        "vite-plus",
        "@voidzero-dev/**",
        "@tailwindcss/vite"
      ]
    }
  ]
}
